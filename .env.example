# Copy values into your shell / OS environment. Do not commit real secrets.
# Windows PowerShell (current session):
#   $env:DB_PASSWORD = "your-new-password"
#   $env:JWT_SECRET = "a-long-random-secret-at-least-32-characters"

DB_URL=jdbc:mysql://localhost:3306/ecommerce_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=replace-with-your-mysql-password

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRATION_MS=86400000

ADMIN_EMAIL=admin@ecommerce.com
ADMIN_PASSWORD=Admin@12345
ADMIN_FULL_NAME=System Admin
